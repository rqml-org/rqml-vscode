    </traceEdge>
    <traceEdge id="TR-034" from="REQ-AGT-013" to="REQ-AGT-010" type="constrains">
      <notes>Strictness level (REQ-AGT-013) constrains spec-code sync commentary (REQ-AGT-010)—ghost feature tolerance varies by level.</notes>
    </traceEdge>
    <traceEdge id="TR-035" from="REQ-AGT-014" to="REQ-AGT-013" type="refines">
