<rqml xmlns="https://rqml.org/schema/2.0.1"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://rqml.org/schema/2.0.1 https://rqml.org/schema/rqml-2.0.1.xsd"
      version="2.0.1" docId="DOC-RQML-VSCODE-001" status="draft">
  <meta>
    <title>RQML extension for VSCode - Requirements specification</title>
    <system>RQML extension for Visual Studio Code</system>
  </meta>
  <goals>
    <goal id="GOAL-SE-PRINCIPLES" title="Preserve software engineering rigor" priority="must" status="draft">
      <statement>Enable proper software engineering principles to remain viable and practical in an era where code is increasingly written by LLMs.</statement>
      <rationale>As LLMs become primary code generators, there is a risk that foundational practices—requirements traceability, specification-driven development, and systematic verification—are bypassed in favor of speed. RQML provides structure that keeps these principles accessible and enforceable, ensuring that LLM-generated code is grounded in intentional design rather than ad-hoc prompting.</rationale>
    </goal>
    <goal id="GOAL-STAKEHOLDER-COMM" title="Facilitate stakeholder communication" priority="must" status="draft">
      <statement>Aid clear and effective communication among all project stakeholders—developers, product owners, QA, and business representatives—through a shared, structured artifact.</statement>
      <rationale>Miscommunication between stakeholders is a leading cause of project failure. By centralizing intent, acceptance criteria, and traceability in a machine-readable yet human-reviewable format, RQML becomes a single source of truth that bridges technical and non-technical perspectives.</rationale>
    </goal>
    <goal id="GOAL-LLM-CONTEXT" title="Maintain LLM coding context" priority="must" status="draft">
      <statement>Provide LLMs with a persistent, well-structured context from which to generate and modify code, improving output quality and reducing token consumption over time.</statement>
      <rationale>LLMs perform better when given clear, consistent context. Without a specification artifact, each coding session starts from scratch or relies on scattered comments and documentation. RQML serves as a durable context anchor—reducing repetitive prompting, minimizing hallucination, and enabling LLMs to produce code that aligns with documented requirements.</rationale>
    </goal>
    <qgoal id="QGOAL-CODE-QUALITY" title="Improve generated code quality" priority="should" status="draft">
      <statement>Achieve measurably higher code quality in LLM-generated outputs when using RQML-driven workflows compared to ad-hoc prompting.</statement>
      <metric>Reduction in defect density; increased first-pass acceptance of generated code; improved alignment with stated requirements as measured by traceability coverage.</metric>
    </qgoal>
    <qgoal id="QGOAL-TOKEN-EFFICIENCY" title="Reduce long-term token usage" priority="should" status="draft">
      <statement>Lower cumulative token consumption for LLM interactions over the lifecycle of a project by providing reusable, structured context.</statement>
      <metric>Reduction in average tokens per feature implementation compared to baseline non-RQML workflows; decrease in repeated context-setting prompts.</metric>
    </qgoal>
    <goalLink id="GL-001" from="QGOAL-CODE-QUALITY" to="GOAL-LLM-CONTEXT" type="refines"/>
    <goalLink id="GL-002" from="QGOAL-TOKEN-EFFICIENCY" to="GOAL-LLM-CONTEXT" type="refines"/>
  </goals>
  <requirements>
    <reqPackage id="PKG-UI" title="VS Code UI surfaces">
      <description>UI requirements for the Activity Bar, Sidebar, Panel, and Status Bar.</description>
      <req id="REQ-UI-001" type="UXR" title="Activity Bar icon" status="approved" priority="must">
        <statement>The extension SHALL contribute an RQML icon to the VS Code Activity Bar.</statement>
        <acceptance>
          <criterion id="AC-UI-001-01">
            <then>An RQML icon is visible in the Activity Bar when the extension is installed and enabled.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-002" type="FR" title="Open RQML overview" status="approved" priority="must">
        <statement>Clicking the Activity Bar RQML icon SHALL open the RQML overview in the VS Code sidebar.</statement>
        <acceptance>
          <criterion id="AC-UI-002-01">
            <when>The user clicks the RQML icon in the Activity Bar.</when>
            <then>The RQML overview view is displayed in the Sidebar.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-003" type="UXR" title="Sidebar three-region layout" status="approved" priority="must">
        <statement>The RQML Sidebar SHALL be split vertically into three regions: Overview (top), Details (middle), and Traces (bottom).</statement>
        <acceptance>
          <criterion id="AC-UI-003-01">
            <then>The Sidebar shows three vertically stacked regions labeled "Overview", "Details", and "Traces".</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-004" type="UXR" title="Resizable regions" status="approved" priority="must">
        <statement>The dividers between the three Sidebar regions SHALL be resizable by the user.</statement>
        <acceptance>
          <criterion id="AC-UI-004-01">
            <when>The user drags a divider between any two regions.</when>
            <then>The sizes of the adjacent regions adjust accordingly.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-005" type="FR" title="Tree view of specification" status="approved" priority="must">
        <statement>The Overview region of the Sidebar SHALL display a tree view of the RQML specification.</statement>
        <acceptance>
          <criterion id="AC-UI-005-01">
            <then>The Overview region contains a hierarchical tree representing the RQML document structure.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006" type="FR" title="Selection details view" status="approved" priority="must">
        <statement>The Details region of the Sidebar SHALL display properties and information for the item selected in the tree view.</statement>
        <acceptance>
          <criterion id="AC-UI-006-01">
            <when>The user selects an item in the tree view.</when>
            <then>The Details region updates to show property information for the selected item.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006A" type="UXR" title="Show all RQML sections" status="approved" priority="must">
        <statement>The tree view SHALL display all RQML sections, including sections not present in the spec.</statement>
        <acceptance>
          <criterion id="AC-UI-006A-01">
            <then>Each RQML section appears as a node in the tree view even when the section has no content in the document.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006B" type="UXR" title="Visual distinction for missing sections" status="approved" priority="must">
        <statement>Sections that are not present in the spec SHALL be visually distinct in the tree view.</statement>
        <notes>Example: gray text and italic styling.</notes>
        <acceptance>
          <criterion id="AC-UI-006B-01">
            <then>Missing sections are rendered with a distinct visual style from present sections.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006C" type="FR" title="Hover actions for section creation" status="draft" priority="must">
        <statement>Hovering over a section node in the tree view SHALL reveal icons for creating new items within that section.</statement>
        <notes>Some sections may support multiple item types; the UI should expose available item types per section.</notes>
        <acceptance>
          <criterion id="AC-UI-006C-01">
            <when>The user hovers over a section node.</when>
            <then>Creation icons appear on the right side of the section row.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006D" type="FR" title="Edit item in form" status="draft" priority="must">
        <statement>Double-clicking an individual item in the tree view SHALL open a UI form to edit that item.</statement>
        <acceptance>
          <criterion id="AC-UI-006D-01">
            <when>The user double-clicks an item in the tree view.</when>
            <then>An edit form opens for the selected item.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006E" type="FR" title="Context menu actions" status="draft" priority="must">
        <statement>Right-clicking (or control-clicking on macOS) an item in the tree view SHALL open a context menu with actions to rename and delete the item.</statement>
        <acceptance>
          <criterion id="AC-UI-006E-01">
            <when>The user right-clicks or control-clicks an item in the tree view.</when>
            <then>A context menu is shown with rename and delete actions.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006F" type="FR" title="Go to definition" status="approved" priority="must">
        <statement>The tree view context menu SHALL include a "Go to definition" action that navigates to the relevant location in the RQML instance document, opening it in the editor if needed.</statement>
        <acceptance>
          <criterion id="AC-UI-006F-01">
            <when>The user selects "Go to definition" on a tree view item.</when>
            <then>The RQML instance document opens in the editor (if not already open) and focus moves to the item definition.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006G" type="UXR" title="Tree root label" status="approved" priority="must">
        <statement>The root node of the tree view SHALL be labeled "RQML Spec".</statement>
        <acceptance>
          <criterion id="AC-UI-006G-01">
            <then>The tree view displays a root node labeled "RQML Spec".</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006H" type="FR" title="View title toolbar actions" status="approved" priority="must">
        <statement>The Overview view title bar SHALL display four action icons: Document, Graph, Grid, and Lightbulb.</statement>
        <acceptance>
          <criterion id="AC-UI-006H-01">
            <then>Four action icons appear in the Overview view's title bar (view/title menu).</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006I" type="FR" title="Root actions behavior" status="approved" priority="must">
        <statement>The four root action icons SHALL open the following editor views: Document opens a WYSIWYG full-spec view with chapters for each RQML section; Arrow opens a traceability map; Grid opens a requirements-to-test-cases matrix with status coloring; Lightbulb opens an LLM-assisted ideas view for improvements or new features in the spec.</statement>
        <acceptance>
          <criterion id="AC-UI-006I-01">
            <when>The user selects the Document icon.</when>
            <then>A WYSIWYG editor view of the full spec opens with chapters for each section.</then>
          </criterion>
          <criterion id="AC-UI-006I-02">
            <when>The user selects the Arrow icon.</when>
            <then>A traceability map view opens in the editor.</then>
          </criterion>
          <criterion id="AC-UI-006I-03">
            <when>The user selects the Grid icon.</when>
            <then>A requirements-to-test-cases grid opens with red/amber/green status indicators.</then>
          </criterion>
          <criterion id="AC-UI-006I-04">
            <when>The user selects the Lightbulb icon.</when>
            <then>An LLM-assisted ideas view opens for improvements or new spec features.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006J" type="FR" title="Traces view" status="approved" priority="must">
        <statement>The Traces region of the Sidebar SHALL display a list of all trace edges that the selected item participates in.</statement>
        <acceptance>
          <criterion id="AC-UI-006J-01">
            <when>The user selects an item in the tree view that has trace edges.</when>
            <then>The Traces region shows a list of all trace edges where the item is either the source or target.</then>
          </criterion>
          <criterion id="AC-UI-006J-02">
            <then>Each trace entry displays the trace type (e.g., dependsOn, implements, verifies) and the linked item ID.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006K" type="FR" title="Clickable trace IDs" status="approved" priority="must">
        <statement>Linked item IDs in the Traces view SHALL be clickable to navigate to the related item.</statement>
        <acceptance>
          <criterion id="AC-UI-006K-01">
            <when>The user clicks on a linked item ID in the Traces view.</when>
            <then>The tree view navigates to and selects the clicked item.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-006L" type="FR" title="Synchronized view updates" status="approved" priority="must">
        <statement>When the user navigates via a clickable ID in the Traces view, all three Sidebar views SHALL update to reflect the newly selected item.</statement>
        <acceptance>
          <criterion id="AC-UI-006L-01">
            <when>The user clicks a linked item ID in the Traces view.</when>
            <then>The Overview highlights and reveals the target item, the Details view shows the item's properties, and the Traces view shows the item's trace edges.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-007" type="FR" title="Open detail views" status="draft" priority="should">
        <statement>Double-clicking an item in the Sidebar overview SHOULD open a detailed view for that item in the editor.</statement>
        <notes>This behavior may be restricted to a pro tier.</notes>
        <acceptance>
          <criterion id="AC-UI-007-01">
            <when>The user double-clicks an item in the Sidebar overview.</when>
            <then>A detailed editor view for the item opens, subject to licensing or tier constraints.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-008" type="FR" title="Spec activity panel view" status="draft" priority="must">
        <statement>The Panel SHALL include a tab named "Spec" that shows activity and changes to the requirements specification.</statement>
        <acceptance>
          <criterion id="AC-UI-008-01">
            <then>The Panel contains a "Spec" tab with a list or timeline of spec activity/changes.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-009" type="FR" title="Nonconformity warnings" status="draft" priority="must">
        <statement>The "Spec" Panel view SHALL show warnings about nonconformity between the specification and expected structure or rules.</statement>
        <acceptance>
          <criterion id="AC-UI-009-01">
            <when>The specification contains a detectable nonconformity.</when>
            <then>A warning is shown in the "Spec" Panel view describing the issue.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-013" type="FR" title="Semantic diagnostics" status="draft" priority="must">
        <statement>The extension SHALL perform semantic diagnostics to detect ambiguous language, missing IDs, and inconsistent priorities, and display them in the Problems panel.</statement>
        <acceptance>
          <criterion id="AC-UI-013-01">
            <when>The RQML spec contains ambiguous language, missing IDs, or inconsistent priorities.</when>
            <then>Corresponding diagnostics appear in the Problems panel.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-013A" type="FR" title="Real-time validation" status="approved" priority="must">
        <statement>The extension SHALL validate the RQML specification file upon any change and report validation errors to the Problems panel.</statement>
        <acceptance>
          <criterion id="AC-UI-013A-01">
            <when>The user modifies and saves the RQML spec file.</when>
            <then>Validation is performed and any errors appear in the Problems panel.</then>
          </criterion>
          <criterion id="AC-UI-013A-02">
            <when>The RQML spec file contains malformed XML.</when>
            <then>An error diagnostic appears in the Problems panel indicating the XML parse error.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-013B" type="FR" title="XSD schema validation" status="approved" priority="must">
        <statement>The extension SHALL validate the RQML specification file against the RQML XSD schema and report schema validation errors to the Problems panel.</statement>
        <acceptance>
          <criterion id="AC-UI-013B-01">
            <when>The RQML spec file contains elements or attributes not conforming to the RQML schema.</when>
            <then>A schema validation error appears in the Problems panel with the line number and description of the violation.</then>
          </criterion>
          <criterion id="AC-UI-013B-02">
            <then>The XSD schema is loaded once into memory at extension activation for efficient validation.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-014" type="FR" title="RQML language mode" status="approved" priority="must">
        <statement>The extension SHALL provide an RQML language mode with syntax highlighting, folding, and XML awareness tailored to RQML.</statement>
        <acceptance>
          <criterion id="AC-UI-014-01">
            <then>RQML files open with an RQML language mode that supports syntax highlighting, folding, and RQML-specific XML awareness.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-010" type="OR" title="Status bar spec indicator" status="approved" priority="must">
        <statement>The Status Bar SHALL show an indicator with four states: Spec invalid, Spec incomplete, Spec unimplemented, and Spec synced.</statement>
        <notes>
          Spec invalid: the RQML spec file is not well-formed XML or not valid against the RQML schema.
          Spec incomplete: there are unspecced features in the code.
          Spec unimplemented: parts or all of the spec are not implemented in code.
          Spec synced: all features in the spec have been implemented in code and are in sync.
        </notes>
        <acceptance>
          <criterion id="AC-UI-010-01">
            <then>The Status Bar displays a distinct state label matching one of the four defined states.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-011" type="FR" title="Offer spec creation" status="approved" priority="must">
        <statement>If no RQML spec file is present in the project root, the extension SHALL offer to create one.</statement>
        <acceptance>
          <criterion id="AC-UI-011-01">
            <when>The extension activates in a workspace with no RQML spec file in the project root.</when>
            <then>The user is prompted with an option to create a new RQML spec file.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-UI-012" type="FR" title="Multiple spec files error" status="approved" priority="must">
        <statement>If more than one .rqml file exists in the project root, the extension SHALL show an error to the user.</statement>
        <acceptance>
          <criterion id="AC-UI-012-01">
            <when>The extension detects multiple .rqml files in the project root.</when>
            <then>An error is shown indicating multiple RQML spec files were found.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-AUTH" title="Authentication and Subscription">
      <description>Requirements for user authentication, login providers, and subscription tiers that gate access to certain features.</description>
      <req id="REQ-AUTH-001" type="FR" title="GitHub login" status="draft" priority="must">
        <statement>The extension SHALL allow users to log in using their GitHub account.</statement>
        <acceptance>
          <criterion id="AC-AUTH-001-01">
            <when>The user initiates login.</when>
            <then>The user is presented with a GitHub OAuth flow and can authenticate with their GitHub credentials.</then>
          </criterion>
          <criterion id="AC-AUTH-001-02">
            <when>GitHub authentication succeeds.</when>
            <then>The user is logged in and their identity is associated with the extension session.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AUTH-002" type="FR" title="Extensible authentication" status="draft" priority="should">
        <statement>The authentication system SHOULD be designed to support additional login providers in the future.</statement>
        <notes>Potential future providers may include Google, Microsoft, email/password, or SSO. The architecture should not be tightly coupled to GitHub.</notes>
        <acceptance>
          <criterion id="AC-AUTH-002-01">
            <then>The authentication implementation uses an abstraction that allows adding new providers without major refactoring.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AUTH-003" type="FR" title="Login state persistence" status="draft" priority="must">
        <statement>The extension SHALL persist the user's login state across VS Code sessions.</statement>
        <acceptance>
          <criterion id="AC-AUTH-003-01">
            <given>A user who has previously logged in.</given>
            <when>The user reopens VS Code.</when>
            <then>The user remains logged in without needing to re-authenticate.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AUTH-004" type="FR" title="Logout" status="draft" priority="must">
        <statement>The extension SHALL allow users to log out of their account.</statement>
        <acceptance>
          <criterion id="AC-AUTH-004-01">
            <when>The user initiates logout.</when>
            <then>The user's session is terminated and any stored credentials are cleared.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AUTH-005" type="UXR" title="Login UI entry point" status="draft" priority="must">
        <statement>The extension SHALL provide a visible entry point for login in the RQML sidebar when the user is not logged in.</statement>
        <acceptance>
          <criterion id="AC-AUTH-005-01">
            <given>The user is not logged in.</given>
            <then>A login button or prompt is visible in the RQML sidebar.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AUTH-006" type="UXR" title="Logged-in user indicator" status="draft" priority="must">
        <statement>The extension SHALL display an indicator showing the logged-in user's identity when authenticated.</statement>
        <acceptance>
          <criterion id="AC-AUTH-006-01">
            <given>The user is logged in.</given>
            <then>The user's GitHub username or avatar is visible in the RQML sidebar.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SUB-001" type="FR" title="Subscription tiers" status="draft" priority="must">
        <statement>The extension SHALL support three subscription tiers: free, pro, and enterprise.</statement>
        <acceptance>
          <criterion id="AC-SUB-001-01">
            <then>The system recognizes and distinguishes between free, pro, and enterprise subscription levels.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SUB-002" type="FR" title="Feature gating" status="draft" priority="must">
        <statement>The extension SHALL restrict access to certain features based on the user's subscription tier.</statement>
        <notes>Features requiring login or subscription should gracefully indicate the required tier and offer upgrade paths.</notes>
        <acceptance>
          <criterion id="AC-SUB-002-01">
            <given>A feature requires a pro or enterprise subscription.</given>
            <when>A user without the required tier attempts to use the feature.</when>
            <then>The user is informed of the subscription requirement and presented with an option to upgrade.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SUB-003" type="UXR" title="Subscription status display" status="draft" priority="must">
        <statement>The extension SHALL display the user's current subscription tier when logged in.</statement>
        <acceptance>
          <criterion id="AC-SUB-003-01">
            <given>The user is logged in.</given>
            <then>The user's subscription tier (free, pro, or enterprise) is visible in the UI.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SUB-004" type="FR" title="Subscription management link" status="draft" priority="should">
        <statement>The extension SHOULD provide a link or action to manage subscription (upgrade, billing) via an external portal.</statement>
        <acceptance>
          <criterion id="AC-SUB-004-01">
            <when>The user selects the subscription management action.</when>
            <then>The user is directed to an external subscription management portal.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-CONFIG" title="Configuration and Settings">
      <description>Requirements for user-configurable settings including API keys, LLM selection, and UI customization.</description>
      <req id="REQ-CFG-001" type="FR" title="Settings UI" status="approved" priority="must">
        <statement>The extension SHALL provide a settings screen accessible to the user for configuring extension behavior.</statement>
        <acceptance>
          <criterion id="AC-CFG-001-01">
            <then>A settings screen is accessible from the extension UI.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-002" type="FR" title="API key storage" status="approved" priority="must">
        <statement>The settings screen SHALL allow users to store API keys required for LLM-powered features.</statement>
        <acceptance>
          <criterion id="AC-CFG-002-01">
            <when>The user enters an API key in the settings.</when>
            <then>The API key is securely stored and available for LLM feature use.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-003" type="SR" title="Secure API key storage" status="approved" priority="must">
        <statement>API keys SHALL be stored securely using VS Code's secret storage API.</statement>
        <acceptance>
          <criterion id="AC-CFG-003-01">
            <then>API keys are not stored in plain text and are protected by VS Code's secret storage mechanism.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-004" type="FR" title="LLM provider selection" status="approved" priority="must">
        <statement>The settings screen SHALL allow users to select which LLM provider to use when multiple providers are available.</statement>
        <acceptance>
          <criterion id="AC-CFG-004-01">
            <given>The user has configured API keys for multiple LLM providers.</given>
            <then>The settings screen displays a selection control to choose the active LLM provider.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-005" type="UXR" title="VS Code theme integration" status="approved" priority="must">
        <statement>The extension SHALL follow the active VS Code colour theme. All views and webviews SHALL use VS Code CSS custom properties for foreground, background, border, and accent colours. No custom colour palette selection is provided.</statement>
        <acceptance>
          <criterion id="AC-CFG-005-01">
            <when>The user switches the VS Code colour theme (e.g., from light to dark).</when>
            <then>All extension views and webviews adapt to the new theme automatically.</then>
          </criterion>
          <criterion id="AC-CFG-005-02">
            <then>No colour palette setting or selection command is exposed to the user.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-007" type="FR" title="Settings persistence" status="approved" priority="must">
        <statement>The extension SHALL persist user settings across VS Code sessions.</statement>
        <acceptance>
          <criterion id="AC-CFG-007-01">
            <given>The user has configured settings.</given>
            <when>The user reopens VS Code.</when>
            <then>Previously configured settings are retained.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-008" type="FR" title="LLM endpoint list view" status="draft" priority="must">
        <statement>The settings screen SHALL display a list of all configured LLM endpoints, showing the provider name and a masked representation of the API key for each entry.</statement>
        <acceptance>
          <criterion id="AC-CFG-008-01">
            <then>The settings screen shows a list of configured LLM endpoints with provider names and masked API keys.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-009" type="SR" title="Hidden API keys in list" status="draft" priority="must">
        <statement>API keys displayed in the LLM endpoint list SHALL be masked (e.g., showing only the last four characters) and SHALL NOT be fully visible to the user.</statement>
        <acceptance>
          <criterion id="AC-CFG-009-01">
            <then>Each API key in the endpoint list is displayed in a masked format such as "••••••••abcd".</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-010" type="FR" title="Active endpoint selection" status="draft" priority="must">
        <statement>Each configured LLM endpoint in the list SHALL have a checkbox that allows the user to designate it as the active endpoint used by the agent.</statement>
        <notes>Only one endpoint may be active at a time. Selecting one deselects any previously active endpoint.</notes>
        <acceptance>
          <criterion id="AC-CFG-010-01">
            <when>The user checks the checkbox next to an endpoint.</when>
            <then>That endpoint becomes the active LLM used by the agent and any previously active endpoint is deselected.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-011" type="FR" title="Remove endpoint" status="draft" priority="must">
        <statement>The user SHALL be able to remove a configured LLM endpoint from the list, which also deletes the associated API key from secure storage.</statement>
        <acceptance>
          <criterion id="AC-CFG-011-01">
            <when>The user removes an endpoint from the list.</when>
            <then>The endpoint is removed from the configuration and its API key is deleted from secure storage.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CFG-012" type="FR" title="Add LLM endpoint dialog" status="draft" priority="must">
        <statement>The settings screen SHALL include an "Add LLM endpoint" button that opens a dialog for configuring a new LLM endpoint, including provider selection and API key entry.</statement>
        <acceptance>
          <criterion id="AC-CFG-012-01">
            <when>The user clicks the "Add LLM endpoint" button.</when>
            <then>A dialog opens allowing the user to select a provider and enter an API key.</then>
          </criterion>
          <criterion id="AC-CFG-012-02">
            <when>The user completes the dialog and confirms.</when>
            <then>The new endpoint appears in the endpoint list and the API key is stored securely.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-API" title="External API Integration">
      <description>Requirements for integration with the external RQML.ai backend API. Implementation deferred to a later phase.</description>
      <req id="REQ-API-001" type="IR" title="Backend API base URL" status="draft" priority="must">
        <statement>The extension SHALL use https://rqml.ai/api as the base URL for external API calls.</statement>
        <notes>Implementation deferred. This requirement establishes the API endpoint for future backend integration.</notes>
        <acceptance>
          <criterion id="AC-API-001-01">
            <then>All external API requests are directed to the https://rqml.ai/api endpoint.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-API-002" type="FR" title="Pro/enterprise feature API dependency" status="draft" priority="must">
        <statement>Certain pro-tier and enterprise-tier features SHALL require communication with the external RQML.ai API.</statement>
        <notes>Implementation deferred. Specific features requiring API access to be defined as they are developed.</notes>
        <acceptance>
          <criterion id="AC-API-002-01">
            <given>A feature is designated as requiring backend API access.</given>
            <when>The user invokes that feature.</when>
            <then>The extension communicates with the RQML.ai API to fulfill the request.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-API-003" type="SR" title="Authenticated API requests" status="draft" priority="must">
        <statement>API requests to RQML.ai SHALL be authenticated using the user's login credentials or session token.</statement>
        <notes>Implementation deferred. Authentication mechanism to align with REQ-AUTH requirements.</notes>
        <acceptance>
          <criterion id="AC-API-003-01">
            <given>The user is logged in.</given>
            <when>The extension makes an API request to RQML.ai.</when>
            <then>The request includes valid authentication credentials.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-API-004" type="FR" title="API error handling" status="draft" priority="must">
        <statement>The extension SHALL gracefully handle API errors including network failures, timeouts, and server errors.</statement>
        <notes>Implementation deferred.</notes>
        <acceptance>
          <criterion id="AC-API-004-01">
            <when>An API request fails due to network or server error.</when>
            <then>The user is shown an appropriate error message and the extension remains functional for offline features.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-API-005" type="FR" title="Offline mode for free features" status="draft" priority="must">
        <statement>Features available in the free tier SHALL remain functional without API connectivity.</statement>
        <acceptance>
          <criterion id="AC-API-005-01">
            <given>The extension cannot reach the RQML.ai API.</given>
            <then>Free-tier features continue to work normally.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-EXPORT" title="Document Export">
      <description>Requirements for exporting the RQML specification as readable documents in various formats.</description>
      <req id="REQ-EXP-001" type="FR" title="Export to HTML" status="draft" priority="must">
        <statement>The extension SHALL allow users to export the RQML specification as an HTML document.</statement>
        <notes>Available in the free tier.</notes>
        <acceptance>
          <criterion id="AC-EXP-001-01">
            <when>The user selects the HTML export option.</when>
            <then>A readable HTML document representing the full specification is generated and saved.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-EXP-002" type="FR" title="Export to PDF" status="draft" priority="must">
        <statement>The extension SHALL allow users to export the RQML specification as a PDF document.</statement>
        <notes>Requires pro tier subscription.</notes>
        <acceptance>
          <criterion id="AC-EXP-002-01">
            <given>The user has a pro or enterprise subscription.</given>
            <when>The user selects the PDF export option.</when>
            <then>A readable PDF document representing the full specification is generated and saved.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-EXP-003" type="FR" title="Export to Markdown" status="draft" priority="must">
        <statement>The extension SHALL allow users to export the RQML specification as a Markdown document.</statement>
        <notes>Requires pro tier subscription.</notes>
        <acceptance>
          <criterion id="AC-EXP-003-01">
            <given>The user has a pro or enterprise subscription.</given>
            <when>The user selects the Markdown export option.</when>
            <then>A readable Markdown document representing the full specification is generated and saved.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-EXP-004" type="FR" title="Export to Word" status="draft" priority="must">
        <statement>The extension SHALL allow users to export the RQML specification as a Microsoft Word document (.docx).</statement>
        <notes>Requires pro tier subscription.</notes>
        <acceptance>
          <criterion id="AC-EXP-004-01">
            <given>The user has a pro or enterprise subscription.</given>
            <when>The user selects the Word export option.</when>
            <then>A readable Word document representing the full specification is generated and saved.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-EXP-005" type="UXR" title="Export UI access" status="draft" priority="must">
        <statement>The extension SHALL provide an "Export" action in the context menu of the root node ("RQML Spec") in the specification tree view.</statement>
        <acceptance>
          <criterion id="AC-EXP-005-01">
            <when>The user right-clicks (or control-clicks on macOS) the root node in the tree view.</when>
            <then>A context menu appears containing an "Export" action.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-EXP-006" type="UXR" title="Export format selection" status="draft" priority="must">
        <statement>When initiating an export, the user SHALL be presented with a selection of available formats based on their subscription tier.</statement>
        <acceptance>
          <criterion id="AC-EXP-006-01">
            <given>The user initiates an export.</given>
            <then>A format selection is shown, with pro-tier formats visually distinguished or disabled for free-tier users.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-AGENT" title="Requirements Agent">
      <description>An LLM-powered agent that monitors the RQML specification and codebase, assesses requirements quality, suggests improvements, and comments on spec-code synchronisation. The agent operates exclusively on the specification—it never modifies source code.</description>
      <req id="REQ-AGT-001" type="FR" title="Agent panel tab" status="draft" priority="must">
        <statement>The VS Code Panel SHALL include a tab with the default heading "RQML AGENT" that hosts the agent interface.</statement>
        <acceptance>
          <criterion id="AC-AGT-001-01">
            <then>A tab labeled "RQML AGENT" is present in the VS Code Panel area.</then>
          </criterion>
          <criterion id="AC-AGT-001-02">
            <when>The user opens the RQML AGENT tab.</when>
            <then>The agent interface is displayed with a prompt input area and a conversation history area.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-002" type="FR" title="Prompt input" status="draft" priority="must">
        <statement>The agent SHALL accept written input from the user via a text prompt in the RQML AGENT panel.</statement>
        <acceptance>
          <criterion id="AC-AGT-002-01">
            <when>The user types a message in the prompt and submits it.</when>
            <then>The message is sent to the configured LLM and a response is displayed in the conversation area.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-003" type="IR" title="Vercel AI SDK integration" status="draft" priority="must">
        <statement>The agent SHALL use the Vercel AI SDK for all LLM communication, supporting multiple provider backends through a unified interface.</statement>
        <notes>The Vercel AI SDK provides a provider-agnostic abstraction over OpenAI, Anthropic, Google, and other LLM APIs.</notes>
        <acceptance>
          <criterion id="AC-AGT-003-01">
            <then>LLM requests are routed through the Vercel AI SDK.</then>
          </criterion>
          <criterion id="AC-AGT-003-02">
            <then>Switching between LLM providers does not require code changes—only configuration.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-004" type="FR" title="RQML file change monitoring" status="draft" priority="must">
        <statement>The agent SHALL monitor changes to the RQML specification file and react to modifications by assessing the updated content.</statement>
        <acceptance>
          <criterion id="AC-AGT-004-01">
            <when>The RQML spec file is modified and saved.</when>
            <then>The agent detects the change and may provide feedback on the updated specification in the conversation area.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-005" type="FR" title="Codebase change monitoring" status="draft" priority="must">
        <statement>The agent SHALL monitor changes to the project codebase and react to modifications relevant to spec-code alignment.</statement>
        <acceptance>
          <criterion id="AC-AGT-005-01">
            <when>Source code files in the workspace are modified and saved.</when>
            <then>The agent detects the change and may provide feedback on spec-code synchronisation in the conversation area.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-006" type="FR" title="Quality assessment" status="draft" priority="must">
        <statement>The agent SHALL comment on the overall quality of the requirements specification, identifying weaknesses such as vague language, missing acceptance criteria, untraceable items, and structural gaps.</statement>
        <acceptance>
          <criterion id="AC-AGT-006-01">
            <when>The agent analyses the RQML specification (on event or user prompt).</when>
            <then>The agent produces a quality assessment covering completeness, clarity, traceability, and structural integrity.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-007" type="FR" title="Change suggestions" status="draft" priority="must">
        <statement>The agent SHALL suggest concrete changes and improvements to the RQML specification, presenting them as actionable proposals to the user.</statement>
        <acceptance>
          <criterion id="AC-AGT-007-01">
            <then>Suggestions are displayed as distinct, reviewable proposals in the conversation area, each describing the proposed change and its rationale.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-008" type="FR" title="User-confirmed modifications" status="draft" priority="must">
        <statement>The agent SHALL only apply modifications to the RQML specification after explicit user confirmation. No changes SHALL be made autonomously.</statement>
        <acceptance>
          <criterion id="AC-AGT-008-01">
            <when>The agent proposes a change to the specification.</when>
            <then>The user is presented with accept/reject/allow-all controls before the change is applied.</then>
          </criterion>
          <criterion id="AC-AGT-008-02">
            <when>The user rejects a proposed change.</when>
            <then>The RQML spec file remains unmodified.</then>
          </criterion>
          <criterion id="AC-AGT-008-03">
            <when>The user accepts a proposed change.</when>
            <then>The change is applied to the RQML spec file.</then>
          </criterion>
          <criterion id="AC-AGT-008-04">
            <when>The user selects "allow all" for the current session.</when>
            <then>Subsequent agent-proposed changes are applied automatically for the remainder of the coding session without further confirmation prompts.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-009" type="CR" title="No code modification" status="draft" priority="must">
        <statement>The agent SHALL NOT modify any source code files. The agent operates exclusively on the RQML specification file.</statement>
        <acceptance>
          <criterion id="AC-AGT-009-01">
            <then>No source code file is ever written to or modified by the agent, regardless of user input or agent assessment.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-011" type="CR" title="Software engineering principles" status="draft" priority="must">
        <statement>The agent SHALL follow and promote good software engineering principles at all times, including requirements completeness, unambiguous language, testability, and proper traceability.</statement>
        <acceptance>
          <criterion id="AC-AGT-011-01">
            <then>All agent-generated content adheres to established requirements engineering best practices (e.g., each requirement is atomic, testable, and uniquely identified).</then>
          </criterion>
          <criterion id="AC-AGT-011-02">
            <then>The agent flags violations of software engineering principles when reviewing user-authored specification content.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-012" type="CR" title="XSD schema conformance" status="draft" priority="must">
        <statement>The agent SHALL enforce conformance to the RQML XSD schema at all times. All agent-generated or agent-modified RQML content SHALL be valid against the schema. The agent SHALL observe and follow guidance embedded in XSD comments.</statement>
        <acceptance>
          <criterion id="AC-AGT-012-01">
            <then>Any RQML content produced by the agent validates against the RQML XSD schema without errors.</then>
          </criterion>
          <criterion id="AC-AGT-012-02">
            <then>The agent's system prompt includes the RQML XSD schema content so that the LLM is aware of structural rules and embedded guidance.</then>
          </criterion>
          <criterion id="AC-AGT-012-03">
            <when>The agent detects that the current RQML spec violates the XSD schema.</when>
            <then>The agent reports the schema violation and proposes a corrective change.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-010" type="FR" title="Spec-code sync commentary" status="draft" priority="must">
        <statement>The agent SHALL comment on the synchronisation status between the RQML specification and the project codebase, identifying requirements that appear unimplemented in code and code that appears unspecified in the spec.</statement>
        <acceptance>
          <criterion id="AC-AGT-010-01">
            <when>The agent analyses both the RQML spec and the codebase (on event or user prompt).</when>
            <then>The agent identifies and reports requirements without apparent code implementation and code without corresponding spec entries.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-013" type="FR" title="Strictness level setting" status="draft" priority="must">
        <statement>The extension settings SHALL include a strictness level selector with four options: relaxed, standard, strict, and certified. The agent SHALL adjust its behaviour according to the selected level.</statement>
        <notes>
          relaxed: Prototyping mode. Spec is advisory. Quick iteration allowed.
          standard: Production default. Spec-first for features. Core traces required.
          strict: Full traceability. All behaviour specified. No ghost features.
          certified: Regulated/safety-critical. Audit-grade traces with metadata.
        </notes>
        <acceptance>
          <criterion id="AC-AGT-013-01">
            <then>The extension settings include a strictness selector with the four defined levels.</then>
          </criterion>
          <criterion id="AC-AGT-013-02">
            <when>The user selects "relaxed" strictness.</when>
            <then>The agent treats the specification as advisory and permits quick iteration without requiring full traceability.</then>
          </criterion>
          <criterion id="AC-AGT-013-03">
            <when>The user selects "standard" strictness.</when>
            <then>The agent enforces spec-first development for features and requires core trace edges.</then>
          </criterion>
          <criterion id="AC-AGT-013-04">
            <when>The user selects "strict" strictness.</when>
            <then>The agent requires full traceability, flags all unspecified behaviour, and blocks ghost features.</then>
          </criterion>
          <criterion id="AC-AGT-013-05">
            <when>The user selects "certified" strictness.</when>
            <then>The agent enforces audit-grade traceability with metadata, requires formal elicitation, and demands pre-approved specs before implementation.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGT-014" type="FR" title="AGENTS.md fallback" status="draft" priority="must">
        <statement>When present, the extension settings strictness level SHALL override the strictness level declared in the project's AGENTS.md file. When no settings override is configured, the agent SHALL observe the strictness level and guidelines specified in AGENTS.md.</statement>
        <acceptance>
          <criterion id="AC-AGT-014-01">
            <given>The user has set a strictness level in extension settings.</given>
            <then>The agent uses the settings value regardless of what AGENTS.md declares.</then>
          </criterion>
          <criterion id="AC-AGT-014-02">
            <given>No strictness level is configured in extension settings.</given>
            <when>An AGENTS.md file exists in the workspace root with a strictness declaration.</when>
            <then>The agent uses the strictness level from AGENTS.md.</then>
          </criterion>
          <criterion id="AC-AGT-014-03">
            <given>No strictness level is configured in settings and no AGENTS.md exists.</given>
            <then>The agent defaults to "standard" strictness.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
    <reqPackage id="PKG-CMD" title="Agent Slash Commands">
      <description>Slash commands exposed through the RQML Agent prompt. Commands use a terminal-style syntax (/command [args] [--flags]) and are entered in the agent panel's text input.</description>
      <req id="REQ-CMD-001" type="FR" title="Slash command interface" status="draft" priority="must">
        <statement>The agent SHALL recognise input beginning with "/" as a slash command, parse the command name and any arguments or flags, and execute the corresponding handler. Unrecognised commands SHALL produce an error message listing similar valid commands.</statement>
        <acceptance>
          <criterion id="AC-CMD-001-01">
            <when>The user submits input beginning with "/" followed by a valid command name.</when>
            <then>The agent executes the corresponding command handler rather than sending the input to the LLM as a free-text prompt.</then>
          </criterion>
          <criterion id="AC-CMD-001-02">
            <when>The user submits an unrecognised slash command.</when>
            <then>The agent displays an error message and suggests similar valid commands.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-002" type="UXR" title="Command autocomplete" status="draft" priority="must">
        <statement>The agent prompt input SHALL provide autocomplete suggestions for command names and, where applicable, command arguments as the user types.</statement>
        <acceptance>
          <criterion id="AC-CMD-002-01">
            <when>The user types "/" in the prompt input.</when>
            <then>A list of available commands is shown as autocomplete suggestions.</then>
          </criterion>
          <criterion id="AC-CMD-002-02">
            <when>The user continues typing after "/".</when>
            <then>The autocomplete list is filtered to matching commands.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-003" type="UXR" title="Clickable output references" status="draft" priority="must">
        <statement>Command output that references requirement IDs, file paths, or diagnostic entries SHALL render those references as clickable links that navigate to the corresponding location.</statement>
        <acceptance>
          <criterion id="AC-CMD-003-01">
            <when>Command output contains a requirement ID (e.g., REQ-014).</when>
            <then>The ID is rendered as a clickable link that opens and navigates to the requirement in the editor.</then>
          </criterion>
          <criterion id="AC-CMD-003-02">
            <when>Command output contains a file path or code location.</when>
            <then>The path is rendered as a clickable link that opens the file at the relevant location.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-004" type="FR" title="Help and discovery commands" status="draft" priority="must">
        <statement>The agent SHALL provide help and discovery commands: /help [command] to display usage information for a specific or all commands, /? as an alias for /help, /commands to list all available commands, and /about to display extension metadata and active runtime configuration.</statement>
        <acceptance>
          <criterion id="AC-CMD-004-01">
            <when>The user runs /help without arguments.</when>
            <then>A summary of all available commands is displayed.</then>
          </criterion>
          <criterion id="AC-CMD-004-02">
            <when>The user runs /help with a command name argument.</when>
            <then>Detailed usage information for that specific command is displayed.</then>
          </criterion>
          <criterion id="AC-CMD-004-03">
            <when>The user runs /about.</when>
            <then>Extension version, active workspace, RQML file path, and active provider/model are displayed.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-005" type="FR" title="Session management commands" status="draft" priority="must">
        <statement>The agent SHALL provide session management commands: /clear to reset the chat transcript while preserving settings, /new [name] to start a named session, /compact [goal] to summarise the conversation into working memory, and /export [md|json] to export the session transcript and artifacts.</statement>
        <acceptance>
          <criterion id="AC-CMD-005-01">
            <when>The user runs /clear.</when>
            <then>The conversation history is cleared and agent settings are preserved.</then>
          </criterion>
          <criterion id="AC-CMD-005-02">
            <when>The user runs /new.</when>
            <then>A new agent session is started with an empty conversation history.</then>
          </criterion>
          <criterion id="AC-CMD-005-03">
            <when>The user runs /compact.</when>
            <then>The conversation is summarised into a compact working memory that preserves key context while reducing token usage.</then>
          </criterion>
          <criterion id="AC-CMD-005-04">
            <when>The user runs /export md or /export json.</when>
            <then>The session transcript and key artifacts are exported in the requested format.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-006" type="FR" title="Provider and model management commands" status="draft" priority="must">
        <statement>The agent SHALL provide provider-agnostic LLM management commands: /providers to list configured providers and connection status, /provider use to set the active provider, /models to list available models, /model use to set the active model, /keys to show key status without exposing secrets, /key set and /key unset to manage API keys via Secret Storage, /key test to verify connectivity, and /llm to show a one-line active configuration summary.</statement>
        <acceptance>
          <criterion id="AC-CMD-006-01">
            <when>The user runs /providers.</when>
            <then>All configured providers are listed with their connection status, key presence, and any last error.</then>
          </criterion>
          <criterion id="AC-CMD-006-02">
            <when>The user runs /key set with a provider name.</when>
            <then>The user is prompted to enter an API key, which is stored securely in VS Code Secret Storage.</then>
          </criterion>
          <criterion id="AC-CMD-006-03">
            <when>The user runs /key test.</when>
            <then>A minimal connectivity test is performed against the active (or specified) provider and the result is reported.</then>
          </criterion>
          <criterion id="AC-CMD-006-04">
            <when>The user runs /keys.</when>
            <then>Key status is displayed for all providers without revealing any secret values.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-007" type="FR" title="Spec quality and health commands" status="draft" priority="must">
        <statement>The agent SHALL provide spec quality commands: /status [--full] as the flagship quality assessment showing an overall score, schema validity, structure, requirement quality, traceability, and sync status; /lint [--fix] [--rules] to run lint rules with optional auto-fix; /validate [--schema] to validate against the XSD schema and emit diagnostics; and /score to show the scoring breakdown.</statement>
        <notes>The /status command output includes: overall quality score (0–100) with grade, schema validity, structural completeness, requirement quality metrics (ambiguity, testability, acceptance criteria coverage), traceability coverage, spec-code drift summary, and timestamps. The --full flag adds prioritised issues, suggestions, and jump targets.</notes>
        <acceptance>
          <criterion id="AC-CMD-007-01">
            <when>The user runs /status.</when>
            <then>A quality assessment summary is displayed including a score, schema validity, and sync status.</then>
          </criterion>
          <criterion id="AC-CMD-007-02">
            <when>The user runs /status --full.</when>
            <then>The summary is extended with prioritised issues grouped by category, suggestions, and clickable jump targets.</then>
          </criterion>
          <criterion id="AC-CMD-007-03">
            <when>The user runs /validate.</when>
            <then>The RQML file is validated against the XSD schema, diagnostics are emitted to the Problems panel, and a summary is displayed.</then>
          </criterion>
          <criterion id="AC-CMD-007-04">
            <when>The user runs /lint --fix.</when>
            <then>Lint rules are executed and safe auto-fixes are applied to the RQML spec after user confirmation.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-008" type="FR" title="Sync and traceability commands" status="draft" priority="must">
        <statement>The agent SHALL provide spec-code sync and traceability commands: /sync status [--full] to report drift between spec and code, /sync scan to rebuild the code index, /trace to show implementation and test evidence for a requirement, /link and /unlink to manage trace links, and /diff to show changes since a baseline.</statement>
        <notes>Drift signals include: requirements with no code references, code paths with no requirement, stale tests versus acceptance criteria, and changed code hotspots since last spec update.</notes>
        <acceptance>
          <criterion id="AC-CMD-008-01">
            <when>The user runs /sync status.</when>
            <then>A drift report is displayed identifying unimplemented requirements and unspecified code.</then>
          </criterion>
          <criterion id="AC-CMD-008-02">
            <when>The user runs /trace with a requirement ID.</when>
            <then>Implementation and test evidence for the requirement is displayed; if missing, candidate files/functions are suggested.</then>
          </criterion>
          <criterion id="AC-CMD-008-03">
            <when>The user runs /link with a requirement ID and target.</when>
            <then>A trace link is added or updated for the requirement.</then>
          </criterion>
          <criterion id="AC-CMD-008-04">
            <when>The user runs /diff spec.</when>
            <then>Changes to the spec since the last baseline or snapshot are displayed.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-009" type="FR" title="Implementation planning command" status="draft" priority="must">
        <statement>The agent SHALL provide a /plan command that analyses the current spec, reports whether it is implementation-ready, identifies blocking issues with recommended fixes, and produces a staged implementation plan with goals, inputs, expected outputs, verification steps, and trace expectations for each stage.</statement>
        <notes>The /plan command supports --full for detailed output and --focus to restrict analysis to a specific area or requirement. The agent stores the latest plan internally for use by the /cmd command.</notes>
        <acceptance>
          <criterion id="AC-CMD-009-01">
            <when>The user runs /plan.</when>
            <then>A readiness verdict (READY or NOT READY) is displayed.</then>
          </criterion>
          <criterion id="AC-CMD-009-02">
            <given>The spec is not implementation-ready.</given>
            <when>The user runs /plan.</when>
            <then>Specific blocking issues are listed, each with a recommended fix describing what to change in the spec.</then>
          </criterion>
          <criterion id="AC-CMD-009-03">
            <when>The user runs /plan and the spec is ready (or has only warnings).</when>
            <then>A numbered staged implementation plan is displayed where each stage includes goal, inputs, expected outputs, verification steps, and trace expectations.</then>
          </criterion>
          <criterion id="AC-CMD-009-04">
            <when>The user runs /plan --focus with a requirement ID or area name.</when>
            <then>The plan is scoped to the specified area rather than the full spec.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-010" type="FR" title="Coding agent command generation" status="draft" priority="must">
        <statement>The agent SHALL provide a /cmd command that generates generic, copy-pasteable instructions for external coding agents based on the latest /plan output. The output SHALL include three blocks: an agent prompt with structured instructions, a context-to-load list of files and directories, and a verification block with commands to run.</statement>
        <notes>The /cmd command supports two modes: /cmd next (default) generates instructions for the next incomplete stage, and /cmd all generates instructions for every stage of the plan. Output is designed to work across terminal agents (Claude Code, Codex CLI), IDE agents (Copilot Chat, Cursor), and web agents.</notes>
        <acceptance>
          <criterion id="AC-CMD-010-01">
            <when>The user runs /cmd (or /cmd next).</when>
            <then>Instructions are generated for the next incomplete stage of the current plan, including AGENT PROMPT, CONTEXT TO LOAD, and VERIFY blocks.</then>
          </criterion>
          <criterion id="AC-CMD-010-02">
            <when>The user runs /cmd all.</when>
            <then>Instructions are generated for every stage of the plan in order, each with AGENT PROMPT, CONTEXT TO LOAD, and VERIFY blocks.</then>
          </criterion>
          <criterion id="AC-CMD-010-03">
            <when>The user runs /cmd without a prior /plan.</when>
            <then>The agent notifies the user that no plan exists and suggests running /plan first.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-011" type="FR" title="Diagnostics and troubleshooting commands" status="draft" priority="must">
        <statement>The agent SHALL provide diagnostics commands: /doctor to check extension health (schema availability, validator engine, provider connectivity, workspace permissions, indexing status), /logs [--tail N] to display redacted extension logs, and /feedback to open the issue reporting flow.</statement>
        <acceptance>
          <criterion id="AC-CMD-011-01">
            <when>The user runs /doctor.</when>
            <then>A health report is displayed covering schema, validator, provider, permissions, and indexing status.</then>
          </criterion>
          <criterion id="AC-CMD-011-02">
            <when>The user runs /logs.</when>
            <then>Recent extension and agent logs are displayed with secrets redacted.</then>
          </criterion>
          <criterion id="AC-CMD-011-03">
            <when>The user runs /feedback.</when>
            <then>The feedback or issue reporting flow is opened.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-012" type="FR" title="Command Palette access" status="draft" priority="must">
        <statement>Agent slash commands that perform standalone operations SHALL also be registered as VS Code extension commands accessible through the Command Palette (Shift+Cmd+P / Ctrl+Shift+P). Commands that require arguments SHALL collect them via VS Code quick-pick or input-box prompts when invoked from the palette. Output SHALL be displayed in the agent panel.</statement>
        <notes>Commands suitable for the Command Palette include: /status, /validate, /lint, /score, /sync status, /sync scan, /plan, /cmd, /doctor, /about, /clear, /new, /export, /providers, /keys, /key test, and /feedback. Session-bound conversational commands such as /compact and /trace with complex arguments may be excluded. All palette commands SHALL use the "RQML:" prefix in their title (e.g., "RQML: Status", "RQML: Validate", "RQML: Plan").</notes>
        <acceptance>
          <criterion id="AC-CMD-012-01">
            <when>The user opens the Command Palette and types "RQML".</when>
            <then>All registered RQML agent commands appear in the filtered results.</then>
          </criterion>
          <criterion id="AC-CMD-012-02">
            <when>The user invokes an agent command from the Command Palette.</when>
            <then>The command executes identically to its slash-command counterpart and output appears in the agent panel.</then>
          </criterion>
          <criterion id="AC-CMD-012-03">
            <given>A command requires arguments (e.g., /trace requires a REQ-ID).</given>
            <when>The user invokes the command from the Command Palette.</when>
            <then>VS Code prompts for the required arguments via quick-pick or input-box before executing.</then>
          </criterion>
          <criterion id="AC-CMD-012-04">
            <when>The agent panel is not visible and a command is invoked from the Command Palette.</when>
            <then>The agent panel is automatically opened to display the command output.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>
  </requirements>
  <trace>
    <traceEdge id="TR-001" from="REQ-UI-007" to="REQ-SUB-002" type="dependsOn">
      <notes>Detail view access (REQ-UI-007) depends on subscription tier feature gating (REQ-SUB-002) as it may be restricted to pro tier.</notes>
    </traceEdge>
    <traceEdge id="TR-002" from="REQ-API-002" to="REQ-SUB-001" type="dependsOn">
