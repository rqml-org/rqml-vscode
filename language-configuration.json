{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["<", ">"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "<!--", "close": "-->" }
  ],
  "surroundingPairs": [
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<[^/!?][^>]*[^/]>\\s*$",
      "end": "^\\s*</[^>]+>\\s*$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*<(?!\\?|[^>]*/>|[^>]*/\\s*>)[^>]+>\\s*$",
    "decreaseIndentPattern": "^\\s*</[^>]+>\\s*$"
  },
  "wordPattern": "[\\w\\-]+"
}
